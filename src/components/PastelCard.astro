---
import { Image } from "astro:assets";
import type { Pastel } from "db/config";
import { slugify } from "@/lib/format";

type Props = {
  pastel: Pastel;
};

const { pastel } = Astro.props;
const {
  nombre,
  descripcion,
  imagen,
  precio,
  precioAnytime,
  precioGift,
  imagenAnytime,
  imagenGift,
} = pastel;

const slug = slugify(nombre);

type Size = { name: string; image: string };
const sizes: Size[] = [];
if (precio) sizes.push({ name: "Tradicional", image: imagen });
if (precioAnytime) sizes.push({ name: "Anytime", image: imagenAnytime ?? imagen });
if (precioGift) sizes.push({ name: "Gift", image: imagenGift ?? imagen });
---

<li class="relative flex flex-col" data-carousel>
  <div class="relative">
    {
      sizes.map((size, i) => (
        <a
          href={`pasteles/${slug}`}
          aria-label={`Ver detalles de ${nombre} - ${size.name}`}
          data-slide={i}
          data-active={i === 0 ? "true" : "false"}
          class="data-[active=false]:hidden"
        >
          <Image
            src={size.image}
            alt={`${nombre} - ${size.name}`}
            width={480}
            height={480}
            quality={80}
            loading="lazy"
            class="aspect-square w-full overflow-clip object-cover"
          />
        </a>
      ))
    }
    {
      sizes.length > 1 && (
        <>
          <button
            data-carousel-prev
            aria-label="Tamaño anterior"
            class="group absolute inset-y-0 left-0 flex w-10 items-center justify-center"
          >
            <span class="rounded-full bg-dark/70 p-1.5 text-light backdrop-blur-sm transition group-hover:bg-dark">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m15 18-6-6 6-6" />
              </svg>
            </span>
          </button>
          <button
            data-carousel-next
            aria-label="Siguiente tamaño"
            class="group absolute inset-y-0 right-0 flex w-10 items-center justify-center"
          >
            <span class="rounded-full bg-dark/70 p-1.5 text-light backdrop-blur-sm transition group-hover:bg-dark">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </span>
          </button>
        </>
      )
    }
  </div>

  <h3 class="mb-1 mt-3 font-medium capitalize tracking-tighter ~text-lg/xl">
    {nombre}
  </h3>

  <div class="mb-2 flex flex-wrap gap-1">
    {
      sizes.map((size, i) => (
        <span
          data-tag={i}
          data-active={i === 0 ? "true" : "false"}
          class="cursor-pointer rounded-md border px-2 py-1 text-[10px] capitalize leading-none transition-colors data-[active=false]:border-light/25 data-[active=false]:opacity-60 data-[active=true]:border-brand/50 data-[active=true]:bg-brand/15 data-[active=true]:text-brand-2"
        >
          {size.name}
        </span>
      ))
    }
  </div>

  <p
    class="mb-2 line-clamp-3 font-light leading-relaxed opacity-60 ~text-[0.6rem]/xs"
  >
    {descripcion}
  </p>

  <a
    href={`pasteles/${slug}`}
    class="relative mt-auto flex w-full items-center justify-center rounded-md border border-light/25 bg-dark py-1 text-center leading-none transition duration-75 ease-out hover:border-brand/50 hover:bg-brand/15 hover:text-brand-2 focus:outline-brand ~px-2/4 ~text-xs/sm"
  >
    Ver Producto
  </a>
</li>

<script>
  function initCarousels() {
    document
      .querySelectorAll<HTMLElement>("[data-carousel]:not([data-initialized])")
      .forEach((carousel) => {
        carousel.dataset.initialized = "true";

        const slides =
          carousel.querySelectorAll<HTMLElement>("[data-slide]");
        const tags = carousel.querySelectorAll<HTMLElement>("[data-tag]");
        const prevBtn = carousel.querySelector<HTMLButtonElement>(
          "[data-carousel-prev]",
        );
        const nextBtn = carousel.querySelector<HTMLButtonElement>(
          "[data-carousel-next]",
        );

        if (slides.length <= 1) return;

        let current = 0;

        function goTo(index: number) {
          slides[current].dataset.active = "false";
          tags[current].dataset.active = "false";
          current = (index + slides.length) % slides.length;
          slides[current].dataset.active = "true";
          tags[current].dataset.active = "true";
        }

        tags.forEach((tag, i) => {
          tag.addEventListener("click", () => goTo(i));
        });

        prevBtn?.addEventListener("click", (e) => {
          e.preventDefault();
          goTo(current - 1);
        });

        nextBtn?.addEventListener("click", (e) => {
          e.preventDefault();
          goTo(current + 1);
        });
      });
  }

  initCarousels();
  document.addEventListener("astro:page-load", initCarousels);
</script>
